# Career Oracle - Backend Configuration
# Copy this to .env and fill in your values

# Adzuna API for live salary data (https://developer.adzuna.com)
# Without these, the engine falls back to category-based estimation
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Server config
PORT=8080
LOG_LEVEL=info
CAREERS_JSON_PATH=./data/careers.json
