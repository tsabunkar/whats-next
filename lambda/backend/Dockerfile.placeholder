FROM golang:alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o bootstrap .

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /app/bootstrap /var/task/bootstrap
CMD ["/var/task/bootstrap"]
